<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="match_parent">

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <!-- ================= NIVELACIÓN ================= -->

            <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardElevation="1dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nivelación"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingBottom="8dp"/>

                    <!-- BM -->
                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_cota_bm"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Cota BM"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"/>

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_lectura_bm"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Lectura BM"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- BZ -->
                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_bz_inicial"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="BZ inicial"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"/>

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_bz_final"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="BZ final"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Distancia / Intervalo -->
                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_distancia"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Distancia total (m)"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"/>

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_intervalo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Intervalo (m)"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Diámetro / Cama -->
                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_diametro"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Diámetro tubería (mm)"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"/>

                        <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_cama"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Cama (cm)"
                                    android:inputType="numberDecimal"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Botones -->
                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="12dp">

                        <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_lecturas"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:text="Lecturas"/>

                        <Space
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"/>

                        <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_cotas"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:text="Cotas"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generar_lecturas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Generar lecturas"/>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_perfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ver perfil"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= MATERIALES ================= -->

            <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/chk_materiales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calcular materiales"/>

            <LinearLayout
                    android:id="@+id/layout_materiales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_ancho_zanja"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ancho de zanja (m)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_sobrecama"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Sobrecama (cm)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_relleno_propio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Relleno propio (cm)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_relleno_prestamo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Relleno préstamo (cm)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_desperdicio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Desperdicio (%)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/chk_asfalto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corte de asfalto"/>

                <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_espesor_asfalto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_espesor_asfalto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Espesor asfalto (cm)"
                            android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_materiales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calcular materiales"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
